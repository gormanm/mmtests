#!/bin/bash
SCRIPTDIR=$(dirname $(realpath -s ${BASH_SOURCE[0]}))
. $SCRIPTDIR/../shellpacks/common.sh

MIN=1
MAX=$NUM_LOGICAL_CPUS
CUTOFF=
NR_STEPS_BETWEEN_FORCE=4
PATTERN=topology
DEBUG=no

while [ $# -ge 1 ]; do
	case $1 in
	--min)
		MIN=$2
		shift 2
		;;
	--max)
		MAX=$2
		shift 2
		;;
	--cutoff*)
		CUTOFF=`echo $1 | sed -e 's/.*=//'`
		shift
		;;
	--topology-steps)
		NR_STEPS_BETWEEN_FORCE=$2
		shift 2
		;;
	--stride-topology)
		PATTERN=topology
		shift
		;;
	--stride-large)
		PATTERN=large
		shift
		;;
	--debug)
		DEBUG=yes
		shift
		;;
	*)
		die "Unrecognised option: $1"
		;;
	esac
done

CURRENT=1
STRIDE=1
[ $MAX -le 0    ] && exit
[ $MIN -gt $MAX	] && exit

SMT_REACHED=0
LLC_REACHED=0
SOCKET_REACHED=0
MACHINE_REACHED=0
DOUT=

NODE_STRIDE=3
LLCS_PER_NODE=$((NODE_WEIGHT/LLC_WEIGHT))
if [ $LLCS_PER_NODE -gt 3 ]; then
	NODE_STRIDE=6
fi
[ "$DEBUG" = "yes" ] && DOUT="LLCS_PER_NODE $LLCS_PER_NODE, NODE_STRIDE $NODE_STRIDE\n"

TOPOLOGY_LEVELS="
1:$SMT_WEIGHT:4:SMT
$SMT_WEIGHT:$LLC_WEIGHT:4:LLC
$LLC_WEIGHT:$NODE_WEIGHT:$NODE_STRIDE:NODE
$NODE_WEIGHT:$NUM_LOGICAL_CPUS:2:MACHINE
$NUM_LOGICAL_CPUS:$((NUM_LOGICAL_CPUS*2)):3:MACHINEx2
$NUM_LOGICAL_CPUS:$((NUM_LOGICAL_CPUS*4)):2:MACHINEx4
$((NUM_LOGICAL_CPUS*4)):$MAX:1:MAX
"

gen_topology() {
	CURRENT=1

	LAST_RANGE=
	for RANGE in $TOPOLOGY_LEVELS; do
		FROM=`echo $RANGE | cut -d: -f1`
		TO=`echo $RANGE | cut -d: -f2`
		NR_STEPS_BETWEEN=`echo $RANGE | cut -d : -f3`
		[ "$LAST_RANGE" = "$FROM:$TO"	] && continue
		[ "$FROM"	= "$TO"		] && continue


		LAST_RANGE="$FROM:$TO"
		LEVEL=`echo $RANGE | cut -d: -f4`
		STRIDE=`echo "scale=1; ($TO-$FROM)/$NR_STEPS_BETWEEN" | bc -l`
		[[ $STRIDE =~ ^- ]] && continue

		for CPU in `seq $FROM $STRIDE $TO | cut -d. -f1`; do
			[ "$DEBUG" = "yes" ] && DOUT+="$CPU Level: $LEVEL $FROM:$TO $STRIDE\n"
			VALUES+="$CPU\n"
		done
	done
}

# This atrocity is cut&pasted from rewrite-shellpack with minor changes. No attempt
# was made to fix this and acts as a placeholder to make conversions easier.
gen_large() {
	THREADS=
	START_THREAD=$MIN
	END_THREAD=$MAX
	if [ $END_THREAD -gt $((NUM_LOGICAL_CPUS*8)) ]; then
		THREADS=`seq $START_THREAD 3 8`
		THREADS="$THREADS `seq 12 9 32`"
		THREADS="$THREADS `seq 48 31 $NUM_LOGICAL_CPUS`"
		LAST_STRIDE=$(((END_THREAD-$NUM_LOGICAL_CPUS*2)/8))
		if [ $LAST_STRIDE -le 0 ]; then
			LAST_STRIDE=31
		fi
		THREADS="$THREADS `seq $((NUM_LOGICAL_CPUS*2)) $LAST_STRIDE $END_THREAD`"
	elif [ $END_THREAD -gt 32 ]; then
		THREADS=`seq $START_THREAD 3 8`
		THREADS="$THREADS `seq 12 9 32`"
		THREADS="$THREADS `seq 48 31 $END_THREAD`"
	elif [ $END_THREAD -gt 8 ]; then
		THREADS=`seq $START_THREAD 2 8`
		THREADS="$THREADS `seq 12 6 $END_THREAD`"
	else
		THREADS=`seq $START_THREAD 2 $END_THREAD`
	fi
	if [ `echo $THREADS | awk '{print $NF}'` -ne $END_THREAD ]; then
		THREADS="$THREADS $END_THREAD"
	fi

	for NR_THREADS in $THREADS; do
		if [ $NR_THREADS -lt $MIN ]; then
			continue
		fi
		VALUES+="$NR_THREADS\n"
	done
}

gen_range() {
	VALUES+="$MIN\n"
	VALUES+="$MAX\n"

	[ "$PATTERN" = "topology" ]	&& gen_topology
	[ "$PATTERN" = "large" ]	&& gen_large
}

gen_list() {
	[ "$CUTOFF" = "" ] && CUTOFF=$MAX
	VALUES=
	gen_range
	for N in `printf "$VALUES" | sort -n -u | cut -f1`; do
		[ $N -ge $MIN -a $N -le $MAX -a $N -le $CUTOFF ] && echo $N
	done
}

gen_list
[ "$DEBUG" = "yes" ] && printf "$DOUT" 1>&2
