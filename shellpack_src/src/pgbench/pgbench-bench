#!/bin/bash
###SHELLPACK preamble pgbench-bench 18.3

ROLE=`whoami`
DBUSER=nobody
EFFECTIVE_CACHESIZE=$((756*1048576))
SHARED_BUFFERS=$((32*1048576))
WORK_MEM=$((32*1048576))
MAX_TIME=60
SCALE_FACTOR=1
VACUUM_ARG=-n
MIN_CLIENTS=1
LOADSCRIPT="select-only"

. $SHELLPACK_INCLUDE/monitors.sh

###SHELLPACK parseargBegin
###SHELLPACK parseargInstall
###SHELLPACK parseargParam --effective-cachesize EFFECTIVE_CACHESIZE
###SHELLPACK parseargParam --shared-buffers      SHARED_BUFFERS
###SHELLPACK parseargParam --work-mem            WORK_MEM

###SHELLPACK parseargParam --min-clients	 MIN_CLIENTS
###SHELLPACK parseargParam --max-clients         MAX_CLIENTS
###SHELLPACK parseargParam --scale-factor        SCALE_FACTOR
###SHELLPACK parseargParam --max-time            MAX_TIME
###SHELLPACK parseargParam --loadscript          LOADSCRIPT
###SHELLPACK parseargEnd
###SHELLPACK monitor_hooks

export PGHOST=127.0.0.1
export PGPORT=5432
export PATH=$SHELLPACK_SOURCES/postgresbuild-${VERSION}-installed/bin:$PATH
export LD_LIBRARY_PATH=$SHELLPACK_SOURCES/postgresbuild-${VERSION}-installed/lib
PSQL="$SHELLPACK_SOURCES/postgresbuild-${VERSION}-installed/bin/psql --host /var/run/postgresql/"
RUNDBUSER="su -s /bin/bash $DBUSER -c"

###SHELLPACK init_only_start
	log_info "Starting database for first time as part of init"
	rm -rf $SHELLPACK_SOURCES/postgres*
	$SHELLPACK_INCLUDE/shellpack-bench-postgresbuild --start \
		--effective_cachesize $EFFECTIVE_CACHESIZE \
		--shared_buffers $SHARED_BUFFERS \
		--work_mem $WORK_MEM \
		-v ${VERSION} || die "Failed to get a usable postgres installation"

	$RUNDBUSER "$PSQL template1 -c 'CREATE ROLE $ROLE with LOGIN;'" || die "Failed to create $ROLE role"
	$RUNDBUSER "$PSQL template1 -c 'GRANT ALL PRIVILEGES ON SCHEMA public TO $ROLE;'" || die "Failed to grant privilege to $ROLE role"

	log_info "Stopping database to finish init"
	$SHELLPACK_INCLUDE/shellpack-bench-postgresbuild --stop

	log_info "pgbench installed only as requested"
	exit $SHELLPACK_SUCCESS
###SHELLPACK init_only_end

drop() {
	$RUNDBUSER "$PSQL template1 -c 'DROP DATABASE pgbench;'"
	$RUNDBUSER "$PSQL template1 -c 'DROP ROLE $ROLE;'"
}

cleanup() {
	log_info "Delete database and shutdown."
	drop
	$SHELLPACK_INCLUDE/shellpack-bench-postgresbuild --stop
	cp $SHELLPACK_SOURCES/postgresbuild-${VERSION}-installed/logfile $LOGDIR_RESULTS/dblog
}

log_info "Starting database"
mmtests_activity init
$SHELLPACK_INCLUDE/shellpack-bench-postgresbuild --start \
	--effective_cachesize $EFFECTIVE_CACHESIZE \
	--shared_buffers $SHARED_BUFFERS \
	--work_mem $WORK_MEM \
	-v ${VERSION} || die "Failed to get a usable postgres installation"

log_info "Preparing database"
$RUNDBUSER "$PSQL template1 -c 'DROP DATABASE pgbench;'"
$RUNDBUSER "$PSQL template1 -c 'DROP ROLE $ROLE;'"
$RUNDBUSER "$PSQL template1 -c 'CREATE DATABASE pgbench;'" || die "Failed to setup database"

FILL_FACTOR=100
if [ "$LOADSCRIPT" != "select-only" ]; then
	FILL_FACTOR=90
fi

log_info "Initialising database for pgbench: Scale factor $SCALE_FACTOR, fill factor $FILL_FACTOR"
$TIME_CMD -o $LOGDIR_RESULTS/dbinit-${NR_THREADS}.time \
	pgbench -h $PGHOST -p $PGPORT -i $VACUUM_ARG -s $SCALE_FACTOR -F $FILL_FACTOR pgbench \
	&> $LOGDIR_RESULTS/pgbench-init.log
# Abort if DB init failed
if [ $? != 0 ]; then
	log_error "Database init failed, cleanup"
	cleanup
	log_info "DB Init log below"
	cat $LOGDIR_RESULTS/pgbench-init.log
	die "Database init failed, exit."
fi

# Bound number of PGBENCH threads
# o Use at least one per node
# o Use no more than 1 thread per 8 clients
MIN_PGBENCH_THREADS=$NUMNODES
MAX_PGBENCH_THREADS=$(($NUM_LOGICAL_CPUS/$NUMNODES/8))
[ $MAX_PGBENCH_THREADS -lt $MIN_PGBENCH_THREADS ] && MAX_PGBENCH_THREADS=$MIN_PGBENCH_THREADS

# Pick a warm-up time based on the database size.  Every scale factor is
# roughly 30M so warm for 1 minute per 100M of database size and for at
# least 1 minute.
WARM_TIME=$((SCALE_FACTOR/100))
WARM_TIME=$(clamp $WARM_TIME 60 $MAX_TIME)

log_info "Running pgbench"
cp $SHELLPACK_DATA/pgdata/postgresql.conf $LOGDIR_RESULTS
echo "scale:       $SCALE_FACTOR"		>  $LOGDIR_RESULTS/pgbench.param
echo "warm:        $WARM_TIME"			>> $LOGDIR_RESULTS/pgbench.param
echo "run:         $MAX_TIME"			>> $LOGDIR_RESULTS/pgbench.param
echo "min_threads: $MIN_PGBENCH_THREADS"	>> $LOGDIR_RESULTS/pgbench.param
echo "max_threads: $MAX_PGBENCH_THREADS"	>> $LOGDIR_RESULTS/pgbench.param
echo "min_clients: $MIN_CLIENTS"		>> $LOGDIR_RESULTS/pgbench.param
echo "max_clients: $MAX_CLIENTS"		>> $LOGDIR_RESULTS/pgbench.param
cat $LOGDIR_RESULTS/pgbench.param

TOTAL_TIME=$((WARM_TIME+MAX_TIME))
PGBENCH_CMD="pgbench -h $PGHOST -p $PGPORT -b $LOADSCRIPT -r $VACUUM_ARG -T $TOTAL_TIME -l --aggregate-interval=1"
###SHELLPACK threads_topology_walk_begin $MIN_CLIENTS $MAX_CLIENTS
	PGBENCH_CLIENTS=$NR_THREADS
	PGBENCH_THREADS=$(clamp $PGBENCH_CLIENTS $MIN_PGBENCH_THREADS $MAX_PGBENCH_THREADS)

	BENCH_CMD="$PGBENCH_CMD -c $PGBENCH_CLIENTS -j $PGBENCH_THREADS pgbench"
	log_cmd "$BENCH_CMD"

	mmtests_activity workload-$PGBENCH_CLIENTS
	log_info "Run $PGBENCH_CLIENTS clients over $PGBENCH_THREADS threads for $TOTAL_TIME ($WARM_TIME+$MAX_TIME) seconds"
	monitor_pre_hook $LOGDIR_RESULTS $PGBENCH_CLIENTS
	$TIME_CMD -o $LOGDIR_RESULTS/time-${PGBENCH_CLIENTS}-1 \
		$BENCH_CMD > $LOGDIR_RESULTS/pgbench-$PGBENCH_CLIENTS.log
	if [ $? -ne 0 ]; then
		cat $LOGDIR_RESULTS/pgbench-$PGBENCH_CLIENTS.log
		die "pgbench failed to execute"
	fi
	monitor_post_hook $LOGDIR_RESULTS $NR_THRADS
	for FILE in `ls pgbench_log.*`; do
		mv $FILE $LOGDIR_RESULTS/pgbench-transactions-$PGBENCH_CLIENTS.log
		gzip -f $LOGDIR_RESULTS/pgbench-transactions-$PGBENCH_CLIENTS.log
	done
###SHELLPACK threads_stride_end

cleanup
log_info "pgbench successfully completed"
exit $SHELLPACK_SUCCESS
